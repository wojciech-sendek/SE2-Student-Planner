{
    "ConnectionStrings": {
        "DefaultConnection": "Server=localhost;Database=StudentPlannerDb;Trusted_Connection=True;TrustServerCertificate=True;"
    },
    "Jwt": {
        "Issuer": "StudentPlanner.Api",
        "Audience": "StudentPlanner.Client",
        "SecretKey": "THIS_IS_A_SUPER_SECRET_DEVELOPMENT_KEY_12345",
        "ExpiryMinutes": 60
    },
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "Usos": {
        "AuthorizationEndpoint": "https://USOS_HOST/oauth/authorize",
        "TokenEndpoint": "https://USOS_HOST/oauth/token",
        "ScheduleEndpoint": "https://USOS_HOST/api/schedule",
        "ClientId": "YOUR_USOS_CLIENT_ID",
        "ClientSecret": "YOUR_USOS_CLIENT_SECRET",
        "RedirectUri": "https://localhost:5001/api/usos/callback",
        "Scope": "schedule",
        "OAuthStateLifetimeMinutes": 10
    },
    "Smtp": {
        "Host": "smtp.example.com",
        "Port": 587,
        "EnableSsl": true,
        "Username": "smtp-user",
        "Password": "smtp-password",
        "From": "student-planner@example.com"
    }
}